# ── Coach ─────────────────────────────────────────────────────────────────────
# The email address that will automatically receive the "coach" role on signup
COACH_EMAIL=your-email@example.com

# ── Database ───────────────────────────────────────────────────────────────────
# Set this to a persistent path on Railway volumes (e.g., /data/buildmybody.db)
# For local development, leave empty to use the default backend/buildmybody.db
DB_PATH=/data/buildmybody.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add Authorized redirect URI: https://buildmybody-production.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://buildmybody-production.up.railway.app/api/auth/google/callback

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://buildmybody.up.railway.app
BACKEND_URL=https://buildmybody-production.up.railway.app
NODE_ENV=production

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set this in the Railway frontend service environment variables
VITE_API_URL=https://buildmybody-production.up.railway.app/api
VITE_BACKEND_URL=https://buildmybody-production.up.railway.app

# ── Port ──────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override in production
PORT=3001
